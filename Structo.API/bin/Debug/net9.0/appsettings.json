{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "PRODUCTION_JWT_SECRET_KEY_PLACEHOLDER",
    "Issuer": "Structo.API",
    "Audience": "Structo.Web"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=StructoDb;Username=postgres;Password=PlaceholderPassword",
    "LocalConnection": "Host=localhost;Port=5444;Database=StructoDb;Username=postgres;Password=NewStrongPassword123"
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUDINARY_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "CloudflareR2": {
    "AccessKeyId": "YOUR_CLOUDFLARE_R2_ACCESS_KEY_ID",
    "SecretAccessKey": "YOUR_CLOUDFLARE_R2_SECRET_ACCESS_KEY",
    "BucketName": "structo-storage",
    "ServiceUrl": "YOUR_CLOUDFLARE_R2_SERVICE_URL",
    "PublicBaseUrl": "YOUR_CLOUDFLARE_R2_PUBLIC_BASE_URL"
  },
  "OneSignal": {
    "AppId": "YOUR_ONESIGNAL_APP_ID",
    "RestApiKey": "YOUR_ONESIGNAL_REST_API_KEY"
  }
}